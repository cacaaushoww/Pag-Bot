# Discord Bot
DISCORD_BOT_TOKEN=

# Discord OAuth2 (criar em https://discord.com/developers/applications -> OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Precisa ser cadastrado nos "Redirects" do app no Discord Developer Portal,
# exatamente igual a este valor.
DISCORD_REDIRECT_URI=https://pag-bot.onrender.com/api/auth/callback

# Domínio do painel (front-end). Usado pro CORS e pra redirecionar
# o usuário de volta após o login. NÃO deixe isso como "*".
FRONTEND_ORIGIN=https://seu-painel.com

# String longa e aleatória usada pra assinar o cookie de sessão.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Em desenvolvimento local (sem HTTPS) defina COOKIE_SECURE=false
COOKIE_SECURE=true

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Mercado Pago
MP_ACCESS_TOKEN=

# Canal de logs do Discord (opcional)
LOG_CHANNEL_ID=

PORT=8080
